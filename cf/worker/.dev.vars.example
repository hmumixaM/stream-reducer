# Local dev secrets for `wrangler dev`. Copy to `.dev.vars` and fill in.
# In production these are set with `wrangler secret put <NAME>`.

# Bearer token for the Gemini summary proxy.
GEMINI_API_KEY=replace-with-gemini-proxy-token
# OpenRouter key for Whisper speech-to-text.
OPENROUTER_API_KEY=sk-or-v1-your-key
# Google AI Studio key for on-demand infographic image generation (native
# generateContent). Optional — falls back to GEMINI_API_KEY when unset.
GEMINI_IMAGE_API_KEY=replace-with-google-ai-studio-key
