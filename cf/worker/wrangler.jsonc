{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stream-reduce",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],

  // Built React SPA (frontend `npm run build` -> ../../frontend/dist).
  // The Worker serves these as static assets and falls back to index.html
  // for client-side routes via the run_worker_first / not_found handling.
  "assets": {
    "directory": "../../frontend/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // Without this, the static-assets layer answers browser navigations to
    // /api/* (e.g. the magic-link GET /api/auth/verify) with the SPA shell
    // before the Worker runs, so React Router 404s. Run the Worker first for
    // server-handled paths; everything else still falls back to the SPA.
    // The /mcp, /oauth/*, and OAuth discovery (/.well-known/oauth-*) paths are
    // handled by the OAuthProvider that wraps the Worker, so they must run the
    // Worker first too — otherwise the assets layer serves the SPA (GET) or a
    // bare 405 (POST) and the MCP/OAuth endpoints never get reached.
    "run_worker_first": [
      "/api/*",
      "/media/*",
      "/mcp",
      "/mcp/*",
      "/oauth/*",
      "/.well-known/oauth-authorization-server",
      "/.well-known/oauth-authorization-server/*",
      "/.well-known/oauth-protected-resource",
      "/.well-known/oauth-protected-resource/*"
    ]
  },

  "observability": { "enabled": true },

  // The Worker is served from the custom domain reducer.xgoose.org. That domain
  // is attached out-of-band via the Workers Custom Domains API (the CI deploy
  // token can't manage zone-level Workers routes), so it is intentionally NOT
  // declared here — declaring it makes `wrangler deploy` fail with a zone-route
  // auth error. The attached domain persists independently of deploys.

  // --- D1: relational store (users, items, user_item, subs, comments, ...) ---
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "stream_reduce",
      "database_id": "60e0f618-ad5c-41ab-88d5-7099f526809a",
      "migrations_dir": "migrations"
    }
  ],

  // --- Vectorize: semantic search over chunk embeddings ---
  "vectorize": [
    {
      "binding": "VECTORIZE",
      "index_name": "stream-reduce-chunks"
    }
  ],

  // --- Workers AI: embeddings (bge-m3) used to fill Vectorize ---
  "ai": { "binding": "AI" },

  // --- R2: downloaded audio media ---
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "stream-reduce-media"
    }
  ],

  // --- KV: OAuth clients, tokens, and grants + Bilibili auth (cookie + token) ---
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "bfba6f4a3950488cb4b0ba9b84e2b879"
    },
    {
      "binding": "BILI_AUTH",
      "id": "b2a287d7866842ef864246119d2e3c72"
    }
  ],

  // --- Queues: pipeline jobs (ingest/transcribe/summarize/embed) ---
  "queues": {
    "producers": [{ "binding": "PIPELINE", "queue": "stream-reduce-pipeline" }],
    "consumers": [
      {
        "queue": "stream-reduce-pipeline",
        "max_batch_size": 1,
        // Each job runs in its own container instance (job-<id>). Keep parallel
        // jobs BELOW `containers[].max_instances` so there's headroom for the
        // auxiliary single-instance containers that also share the pool —
        // subscription feed enumeration (`feed`), the daily Bilibili cookie
        // refresh (`bili-refresh`), metadata (`meta-*`), and `proxy-check`.
        // Without headroom, one of those running alongside max jobs makes the
        // next job 503 ("no Container instance available"). 8 jobs + 2 reserved
        // = the 10 max_instances below. (503s are also self-healed: the
        // consumer re-queues the item instead of failing it.)
        "max_concurrency": 8,
        "max_retries": 3,
        "dead_letter_queue": "stream-reduce-pipeline-dlq"
      }
    ]
  },

  // --- Container: Python pipeline (yt-dlp + ffmpeg + summarize) ---
  // Controlled per-instance through the PipelineContainer Durable Object.
  "containers": [
    {
      "class_name": "PipelineContainer",
      "image": "../pipeline/Dockerfile",
      // Build from the repo root so the Dockerfile can COPY the shared `app/`
      // package (adapters) alongside cf/pipeline/*.py.
      "image_build_context": "../../",
      "instance_type": "standard-2",
      // Total container slots. Kept ABOVE the queue `max_concurrency` (8) so the
      // auxiliary single-instance containers (feed / bili-refresh / meta /
      // proxy-check) have ~2 reserved slots and never starve pipeline jobs into
      // a 503. The short `sleepAfter` in container.ts keeps finished instances
      // from lingering into the next job's slot.
      "max_instances": 10
    }
  ],

  "durable_objects": {
    "bindings": [
      { "class_name": "PipelineContainer", "name": "PIPELINE_CONTAINER" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["PipelineContainer"] }
  ],

  // --- Email Service: magic-link sign-in ---
  "send_email": [{ "name": "EMAIL" }],

  // --- Cron: poll subscriptions (hourly) + nightly graph rebuild ---
  "triggers": {
    "crons": ["*/15 * * * *", "0 4 * * *"]
  },

  "vars": {
    "APP_ORIGIN": "https://reducer.xgoose.org",
    "EMAIL_FROM": "noreply@xgoose.org",
    "LLM_BASE_URL": "https://xgoose-gemini-proxy-1.max-678.workers.dev/v1",
    "LLM_MODEL": "gemini-3.5-flash",
    "LLM_MODEL_INFOGRAPHIC": "gemini-3-pro-image-preview",
    "STT_MODEL": "openai/whisper-large-v3-turbo",
    "EMBEDDING_DIM": "1024",
    "SUBSCRIPTION_WINDOW_DAYS": "90",
    "SUBSCRIPTION_MIN_DURATION_S": "600",
    "GRAPH_KNN_K": "6",
    "GRAPH_SIM_THRESHOLD": "0.6",
    "ADMIN_EMAILS": "huyangmax@gmail.com"
  }

  // Secrets (set via `wrangler secret put`):
  //   GEMINI_API_KEY        - bearer token for the Gemini summary proxy
  //   OPENROUTER_API_KEY    - OpenRouter key for Whisper STT
  //   GEMINI_IMAGE_API_KEY  - Google AI Studio key for infographic image gen
  //                           (native generateContent; the text proxy can't emit
  //                           images). Optional: falls back to GEMINI_API_KEY.
}
