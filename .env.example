# --- Web ---
# Host port to publish the UI/API on (container always serves on 8000).
WEB_PORT=8010

# --- Storage ---
# DATA_DIR=./data
# DATABASE_URL=sqlite:////data/stream_reduce.db

# --- Queue ---
REDIS_URL=redis://localhost:6379/0

# --- LLM: Gemini via LiteLLM proxy (OpenAI-compatible /v1 endpoint) ---
LLM_BASE_URL=https://your-litellm-host/v1
LLM_API_KEY=sk-your-litellm-virtual-key
LLM_MODEL=gemini-3.5-flash
LLM_TEMPERATURE=0.2

# --- Speech-to-text via OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-your-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Options: openai/whisper-large-v3-turbo, google/chirp-3, openai/gpt-4o-transcribe
STT_MODEL=openai/whisper-large-v3-turbo
TRANSCRIBE_CHUNK_SECONDS=300
TRANSCRIBE_RATE_LIMIT=20
TRANSCRIBE_MAX_RETRIES=5
TRANSCRIBE_CONCURRENCY=1

# --- Summarization ---
SUMMARY_PROMPT_VERSION=v1
ENABLE_GEMINI_AUDIO_FALLBACK=false

# --- MCP (AI agent access, mounted at /mcp) ---
ENABLE_MCP=true

# --- Subscriptions ---
DEFAULT_POLL_INTERVAL_MINUTES=60

# --- Behaviour ---
DEFAULT_LANGUAGE=
TRACK_API_CALLS=true
# YT_DLP_COOKIES_FILE=/cookies/cookies.txt
